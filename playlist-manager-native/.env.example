# Expo environment variables — copy to .env and fill in values.
# EXPO_PUBLIC_* vars are bundled into the app binary (visible to client).
# Never put secrets here.

# Auth0 tenant configuration
EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your_native_app_client_id
EXPO_PUBLIC_AUTH0_AUDIENCE=https://your-api-identifier

# Vercel backend API base URL
# In development: use ngrok to expose local server, e.g. https://abc123.ngrok.io
EXPO_PUBLIC_API_BASE_URL=https://your-deployment.vercel.app
